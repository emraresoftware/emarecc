# OpenCC - Environment Variables
# cp .env.example .env ve değerleri düzenleyin

# === Veritabanı ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=secret
DB_NAME=callcenter_db

# === Redis (BullMQ, transkripsiyon job) ===
REDIS_URL=redis://localhost:6379

# === JWT ===
# Production: openssl rand -hex 32 ile güçlü secret üretin
JWT_SECRET=opencc-jwt-secret-change-in-production
JWT_EXPIRES_IN=1h

# === Backend ===
PORT=5001
NODE_ENV=development
RECORDINGS_PATH=/recordings

# === Asterisk AMI (Panelden de ayarlanabilir) ===
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=amiuser
AMI_SECRET=
# Dış arama (PSTN) için trunk adı
AMI_DIAL_TRUNK=
AMI_DIAL_TECH=PJSIP

# === CRM Webhook (Panelden de ayarlanabilir) ===
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# === Wallboard (Panelden de ayarlanabilir) ===
WALLBOARD_PUBLIC_TOKEN=

# === AI Transkripsiyon (Opsiyonel) ===
OPENAI_API_KEY=

# === Public URL (Webhook callback, kayıt URL'leri) ===
PUBLIC_URL=http://localhost:5000
# CRM_BASE_URL=PUBLIC_URL alternatifi

# === Rate Limit ===
RATE_LIMIT_MAX=1000
RATE_LIMIT_LOGIN=50

# === Skill Routing (Opsiyonel) ===
SKILL_ROUTE_TOKEN=
