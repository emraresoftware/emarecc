# Frontend - Environment Variables
# Vite build sırasında VITE_* değişkenleri enjekte edilir

# API ve WebSocket adresleri
# Lokal Vite dev: Boş bırakın veya proxy kullanın
# Docker/Production: Backend adresini verin (HTTPS/WSS önerilir)
VITE_API_URL=http://localhost:5001
VITE_WS_URL=ws://localhost:5001

# WebRTC/SIP.js (opsiyonel — Asterisk PJSIP WebRTC gerekli)
# Tümü tanımlıysa ajan girişinde otomatik SIP kaydı yapılır
# VITE_SIP_WS_URL=wss://callcenter.example.com:8089/ws
# VITE_SIP_DOMAIN=callcenter.example.com
# VITE_SIP_SECRET=your_sip_secret
